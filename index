// ─── Quote Modal ──────────────────────────────────────────────────────────────
function QuoteModal({ repair, onSend, onClose, iStyle }) {
  const [quote, setQuote] = useState(repair.quote || "");
  const [msg, setMsg]     = useState("");
  const [busy, setBusy]   = useState(false);
  async function send() {
    if (!quote) return alert("Enter a quote amount");
    setBusy(true); await onSend(repair.id, quote, msg); setBusy(false);
  }
  const preview = `Hi ${repair.customer_name || "there"}, your ${repair.watch_brand || "watch"} repair quote is $${quote||"___"}.\n${msg ? msg+"\n" : ""}\nReply YES to go ahead or NO to decline.`;
  return (
    <div style={{position:"fixed",inset:0,background:"#000a",zIndex:900,display:"flex",alignItems:"center",justifyContent:"center"}}>
      <div style={{background:"#1a1a2e",borderRadius:16,padding:28,width:480,maxWidth:"94vw",boxShadow:"0 8px 40px #0008"}}>
        <div style={{fontSize:18,fontWeight:700,marginBottom:6}}>Send Quote SMS</div>
        <div style={{fontSize:13,color:"#fff5",marginBottom:20}}>{repair.customer_name} — {repair.watch_brand} — {repair.phone}</div>
        <label style={{fontSize:11,color:"#fff4",letterSpacing:".07em",display:"block",marginBottom:5}}>QUOTE ($)</label>
        <input type="number" value={quote} onChange={e=>setQuote(e.target.value)} placeholder="e.g. 250" style={{...iStyle,fontSize:20,fontWeight:700,marginBottom:14}} />
        <label style={{fontSize:11,color:"#fff4",letterSpacing:".07em",display:"block",marginBottom:5}}>EXTRA MESSAGE (optional)</label>
        <textarea value={msg} onChange={e=>setMsg(e.target.value)} placeholder="e.g. Parts are in stock…" style={{...iStyle,minHeight:60,resize:"vertical",marginBottom:14}} />
        <div style={{background:"#0f0f1a",borderRadius:8,padding:12,marginBottom:18}}>
          <div style={{fontSize:10,color:"#fff3",marginBottom:6}}>SMS PREVIEW</div>
          <div style={{fontSize:12,color:"#fff7",lineHeight:1.7,whiteSpace:"pre-wrap"}}>{preview}</div>
        </div>
        <div style={{display:"flex",gap:10}}>
          <button onClick={send} disabled={busy} style={{flex:1,background:busy?"#6b7280":"#10b981",color:"#fff",border:"none",padding:"12px 20px",borderRadius:8,cursor:busy?"not-allowed":"pointer",fontWeight:700,fontSize:15}}>
            {busy?"Sending…":"📱 Send SMS Quote"}
          </button>
          <button onClick={onClose} style={{background:"transparent",color:"#fff6",border:"1px solid #fff2",padding:"12px 20px",borderRadius:8,cursor:"pointer"}}>Cancel</button>
        </div>
      </div>
    </div>
  );
}

// ─── New Repair Form ──────────────────────────────────────────────────────────
function NewRepairForm({ iStyle, saving, form, setForm, onSave }) {
  const [services,  setServices]  = useState([]);
  const [mvSearch,  setMvSearch]  = useState("");
  const [mvResult,  setMvResult]  = useState(null);
  const [mvError,   setMvError]   = useState(false);
  const [customs,   setCustoms]   = useState([]);
  const [cLabel,    setCLabel]    = useState("");
  const [cPrice,    setCPrice]    = useState("");
  const [scanning,  setScanning]  = useState(false);
  const fileRef = useRef(null);

  function recalc(svcs, mv, custs) {
    const all = [...svcs, ...(mv?[mv]:[]), ...custs];
    const total = all.reduce((s,i)=>s+i.price, 0);
    setForm(p => ({...p, quote: total||"", issue: all.map(i=>`${i.label}: $${i.price}`).join("\n")}));
  }
  function toggleSvc(svc) {
    setServices(prev => {
      const exists = prev.find(s=>s.id===svc.id);
      const item = svc.quoted ? {...svc, label:svc.label+" (to quote)", price:0} : svc;
      const next = exists ? prev.filter(s=>s.id!==svc.id) : [...prev, item];
      recalc(next, mvResult, customs); return next;
    });
  }
  function searchMv() {
    const q = mvSearch.trim().toUpperCase();
    const price = MOVEMENTS[q];
    if (price) {
      const r = {id:"mv", label:`Movement: ${q}`, price};
      setMvResult(r); setMvError(false); recalc(services, r, customs);
    } else { setMvResult(null); setMvError(true); }
  }
  function removeMv() { setMvResult(null); setMvSearch(""); setMvError(false); recalc(services, null, customs); }
  function addCustom() {
    if (!cLabel.trim()||!cPrice) return;
    const item = {id:"c-"+Date.now(), label:cLabel.trim(), price:parseFloat(cPrice)};
    const next = [...customs, item]; setCustoms(next); setCLabel(""); setCPrice("");
    recalc(services, mvResult, next);
  }
  function removeCustom(id) {
    const next = customs.filter(c=>c.id!==id); setCustoms(next); recalc(services, mvResult, next);
  }

  async function handlePhoto(e) {
    const file = e.target.files[0]; if (!file) return;
    setScanning(true);
    try {
      const fd = new FormData(); fd.append("photo", file);
      const res = await fetch(`${SERVER_URL}/analyze-watch`, {method:"POST", body:fd});
      const raw = await res.text();
      console.log("Scan response:", res.status, raw.slice(0,200));
      if (!res.ok) { let m="Server error "+res.status; try{m=JSON.parse(raw).error||m}catch(e){} throw new Error(m); }
      const data = JSON.parse(raw);
      if (data.error) throw new Error(data.error);
      if (data.brand && data.brand!=="null") setForm(p=>({...p, watch_brand:data.brand}));
      if (data.movement && data.movement!=="null") {
        const det = data.movement.toUpperCase().trim();
        const price = MOVEMENTS[det];
        if (price) {
          const r = {id:"mv", label:`Movement: ${det} (Scanned)`, price};
          setMvResult(r); setMvError(false); recalc(services, r, customs);
          alert(`Scan complete!\nBrand: ${data.brand||"—"}\nMovement: ${det} — $${price}`);
        } else {
          setMvSearch(det); setMvError(true);
          alert(`Movement "${det}" not in price list — add as custom item.`);
        }
      } else if (data.brand && data.brand!=="null") {
        alert(`Brand: ${data.brand}\nNo movement visible — enter manually.`);
      } else {
        alert("Couldn't read caseback. Try closer / better lighting.");
      }
    } catch(err) { alert("Scan failed: "+err.message); }
    finally { setScanning(false); if(fileRef.current) fileRef.current.value=""; }
  }

  const allItems = [...services, ...(mvResult?[mvResult]:[]), ...customs];
  const total = allItems.reduce((s,i)=>s+i.price, 0);
  const btn = {border:"none",borderRadius:10,padding:"8px 14px",cursor:"pointer",fontSize:14,fontWeight:600};

  return (
    <div style={{padding:"20px 16px",maxWidth:800}}>
      <h1 style={{margin:"0 0 20px",fontSize:24}}>New Repair Ticket</h1>
      <input type="file" accept="image/*" capture="environment" ref={fileRef} style={{display:"none"}} onChange={handlePhoto} />

      <div style={{background:"#1a1a2e",borderRadius:15,padding:20,marginBottom:16}}>
        <div style={{fontSize:12,color:"#fff4",letterSpacing:".08em",marginBottom:14}}>CUSTOMER & WATCH DETAILS</div>
        <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:12}}>
          {[["team_member","Team Member","text"],["customer_name","Customer Name","text"],["phone","Phone","tel"]].map(([k,l,t])=>(
            <div key={k}>
              <label style={{fontSize:11,color:"#fff4",letterSpacing:".07em",display:"block",marginBottom:5}}>{l.toUpperCase()}</label>
              <input type={t} value={form[k]} onChange={e=>setForm(p=>({...p,[k]:e.target.value}))} style={iStyle} />
            </div>
          ))}
          <div>
            <label style={{fontSize:11,color:"#fff4",letterSpacing:".07em",display:"block",marginBottom:5}}>BRAND / WATCH</label>
            <div style={{display:"flex",gap:8}}>
              <input type="text" value={form.watch_brand} onChange={e=>setForm(p=>({...p,watch_brand:e.target.value}))} style={{...iStyle,flex:1}} />
              <button onClick={()=>fileRef.current?.click()} disabled={scanning}
                style={{background:scanning?"#6b7280":"#10b981",color:"#fff",border:"none",borderRadius:10,padding:"0 12px",cursor:scanning?"not-allowed":"pointer",fontWeight:700,fontSize:16}}>
                {scanning?"⏳":"📸"}
              </button>
            </div>
          </div>
          <div>
            <label style={{fontSize:11,color:"#fff4",letterSpacing:".07em",display:"block",marginBottom:5}}>EST. READY</label>
            <input type="date" value={form.estimated_ready} onChange={e=>setForm(p=>({...p,estimated_ready:e.target.value}))} style={iStyle} />
          </div>
          <div>
            <label style={{fontSize:11,color:"#fff4",letterSpacing:".07em",display:"block",marginBottom:5}}>STATUS</label>
            <select value={form.status} onChange={e=>setForm(p=>({...p,status:e.target.value}))} style={{...iStyle,cursor:"pointer"}}>
              {ALL_STATUSES.map(s=><option key={s} value={s}>{s}</option>)}
            </select>
          </div>
        </div>
      </div>

      <div style={{background:"#1a1a2e",borderRadius:15,padding:20,marginBottom:16}}>
        <div style={{fontSize:12,color:"#fff4",letterSpacing:".08em",marginBottom:16}}>JOB BUILDER</div>
        {Object.entries(CAT_LABELS).map(([cat,catLabel])=>(
          <div key={cat} style={{marginBottom:16}}>
            <div style={{fontSize:12,color:"#c9a84c",letterSpacing:".08em",marginBottom:8}}>{catLabel}</div>
            <div style={{display:"flex",flexWrap:"wrap",gap:6}}>
              {SERVICES.filter(s=>s.cat===cat).map(svc=>{
                const active = services.find(s=>s.id===svc.id);
                return <button key={svc.id} onClick={()=>toggleSvc(svc)}
                  style={{...btn,background:active?"#c9a84c":"#fff1",color:active?"#1a1a2e":"#fff",border:active?"none":"1px solid #fff2"}}>
                  {svc.label} <span style={{opacity:.7,marginLeft:4}}>{svc.quoted?"(Quote)":"$"+svc.price}</span>
                </button>;
              })}
            </div>
          </div>
        ))}

        <div style={{borderTop:"1px solid #fff1",paddingTop:16,marginBottom:16}}>
          <div style={{fontSize:12,color:"#c9a84c",letterSpacing:".08em",marginBottom:8}}>MOVEMENT REPLACEMENT</div>
          <div style={{display:"flex",gap:8,flexWrap:"wrap",alignItems:"center"}}>
            <input placeholder="e.g. 7N42, 2824-2, NH35…" value={mvSearch} onChange={e=>{setMvSearch(e.target.value);setMvError(false);}} onKeyDown={e=>e.key==="Enter"&&searchMv()} style={{...iStyle,maxWidth:260}} />
            <button onClick={searchMv} style={{...btn,background:"#fff2",color:"#fff",padding:"10px 16px"}}>Search</button>
            {mvResult && <div style={{display:"flex",alignItems:"center",gap:8,background:"#c9a84c20",border:"1px solid #c9a84c50",borderRadius:10,padding:"8px 12px"}}>
              <span style={{color:"#c9a84c",fontWeight:700,fontSize:13}}>{mvResult.label} — ${mvResult.price}</span>
              <button onClick={removeMv} style={{background:"transparent",border:"none",color:"#c9a84c",cursor:"pointer",fontSize:18}}>×</button>
            </div>}
          </div>
          {mvError && <div style={{color:"#ef4444",fontSize:13,marginTop:6}}>Not found — add as custom item below</div>}
        </div>

        <div style={{borderTop:"1px solid #fff1",paddingTop:16}}>
          <div style={{fontSize:12,color:"#c9a84c",letterSpacing:".08em",marginBottom:8}}>ADD CUSTOM ITEM</div>
          <div style={{display:"flex",gap:8,flexWrap:"wrap"}}>
            <input placeholder="Description" value={cLabel} onChange={e=>setCLabel(e.target.value)} style={{...iStyle,flex:2,minWidth:160}} />
            <input placeholder="Price $" type="number" value={cPrice} onChange={e=>setCPrice(e.target.value)} onKeyDown={e=>e.key==="Enter"&&addCustom()} style={{...iStyle,width:90}} />
            <button onClick={addCustom} style={{...btn,background:"#fff2",color:"#fff",padding:"10px 16px"}}>Add</button>
          </div>
          {customs.length>0 && <div style={{marginTop:10,display:"flex",flexWrap:"wrap",gap:6}}>
            {customs.map(item=>(
              <div key={item.id} style={{display:"flex",alignItems:"center",gap:8,background:"#fff1",border:"1px solid #fff2",borderRadius:8,padding:"5px 10px"}}>
                <span style={{fontSize:13}}>{item.label} — ${item.price}</span>
                <button onClick={()=>removeCustom(item.id)} style={{background:"transparent",border:"none",color:"#fff6",cursor:"pointer",fontSize:15}}>×</button>
              </div>
            ))}
          </div>}
        </div>
      </div>

      {allItems.length>0 && <div style={{background:"#1a1a2e",borderRadius:15,padding:20,marginBottom:16}}>
        <div style={{fontSize:12,color:"#fff4",letterSpacing:".08em",marginBottom:12}}>QUOTE BREAKDOWN</div>
        {allItems.map((item,i)=>(
          <div key={i} style={{display:"flex",justifyContent:"space-between",padding:"7px 0",borderBottom:"1px solid #fff1",fontSize:14}}>
            <span style={{color:"#fff9"}}>{item.label}</span>
            <span style={{fontWeight:600}}>${item.price}</span>
          </div>
        ))}
        <div style={{display:"flex",justifyContent:"space-between",padding:"12px 0 0",fontSize:20,fontWeight:700}}>
          <span style={{color:"#fff6"}}>TOTAL</span>
          <span style={{color:"#c9a84c"}}>${total}</span>
        </div>
      </div>}

      <div style={{background:"#1a1a2e",borderRadius:15,padding:20,marginBottom:16}}>
        <div style={{fontSize:12,color:"#fff4",letterSpacing:".08em",marginBottom:10}}>NOTES</div>
        <textarea value={form.notes} onChange={e=>setForm(p=>({...p,notes:e.target.value}))} placeholder="Any workshop notes…" style={{...iStyle,minHeight:70,resize:"vertical"}} />
      </div>

      <button onClick={onSave} disabled={saving}
        style={{background:saving?"#6b7280":"#c9a84c",color:"#1a1a2e",border:"none",padding:"13px 28px",borderRadius:12,cursor:saving?"not-allowed":"pointer",fontWeight:700,fontSize:15}}>
        {saving?"Saving…":"Create Ticket & Print →"}
      </button>
    </div>
  );
}

