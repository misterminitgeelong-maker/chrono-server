// ─── Main App ─────────────────────────────────────────────────────────────────
function App() {
  const [repairs,      setRepairs]      = useState([]);
  const [loading,      setLoading]      = useState(true);
  const [error,        setError]        = useState(null);
  const [view,         setView]         = useState("dashboard");
  const [selected,     setSelected]     = useState(null);
  const [search,       setSearch]       = useState("");
  const [filterStatus, setFilterStatus] = useState("All");
  const [saving,       setSaving]       = useState(false);
  const [notification, setNotification] = useState(null);
  const [quoteModal,   setQuoteModal]   = useState(null);
  const [noteInput,    setNoteInput]    = useState("");
  const [scanInput,    setScanInput]    = useState("");
  const [scanResult,   setScanResult]   = useState(null);
  const [scanError,    setScanError]    = useState(false);
  const emptyForm = {team_member:"",customer_name:"",phone:"",watch_brand:"",issue:"",cost_to_business:"",quote:"",estimated_ready:"",status:"Go Ahead",notes:""};
  const [form, setForm] = useState(emptyForm);

  useEffect(()=>{
    const p = new URLSearchParams(window.location.search);
    const action=p.get("action"), repairId=p.get("repair"), response=p.get("response");
    if (action==="respond"&&repairId&&response) doCustomerResponse(repairId, response);
    else if (repairId) loadOne(repairId);
    else load();
  },[]);

  async function doCustomerResponse(repairId, response) {
    setView("responding");
    try {
      const res = await fetch(`${SERVER_URL}/customer-respond`, {
        method:"POST", headers:{"Content-Type":"application/json"},
        body: JSON.stringify({repairId, response})
      });
      const data = await res.json();
      if (!res.ok) throw new Error(data.error);
      setView("response_done"); setSelected({id:repairId, status:data.status, response});
    } catch(e) { setView("response_error"); }
  }

  async function load() {
    try { setLoading(true); setError(null);
      setRepairs(await sbFetch("repairs?order=received_date.desc.nullslast,id.desc"));
    } catch(e) { setError("Could not connect: "+e.message); }
    finally { setLoading(false); }
  }

  async function loadOne(id) {
    try { const d=await sbFetch(`repairs?id=eq.${encodeURIComponent(id)}`);
      if(d.length) { setSelected(d[0]); setView("customer"); }
    } catch(e){} finally { setLoading(false); }
  }

  async function saveRepair() {
    try {
      setSaving(true);
      const id = "WR-"+Date.now();
      const today = new Date().toISOString().slice(0,10);
      const rec = {...form, id, received_date:today,
        cost_to_business: parseFloat(form.cost_to_business)||null,
        quote: parseFloat(form.quote)||null,
        history:[{date:today, event:"Watch received and logged"}]};
      await sbFetch("repairs",{method:"POST",body:JSON.stringify(rec),prefer:"return=representation"});
      await load();
      const saved = await sbFetch(`repairs?id=eq.${id}`);
      if(saved.length) printTicket(saved[0]);
      setView("dashboard"); setForm(emptyForm);
    } catch(e) { alert("Error saving: "+e.message); }
    finally { setSaving(false); }
  }

  async function changeStatus(id, status) {
    try {
      const today=new Date().toISOString().slice(0,10);
      const r = repairs.find(x=>x.id===id)||selected;
      const history=[...(r.history||[]),{date:today,event:`Status: ${status}`}];
      await sbFetch(`repairs?id=eq.${encodeURIComponent(id)}`,{method:"PATCH",body:JSON.stringify({status,history}),prefer:"return=representation"});
      setSelected(p=>p?{...p,status,history}:p);
      setRepairs(p=>p.map(r=>r.id===id?{...r,status,history}:r));
    } catch(e){alert("Error: "+e.message);}
  }

  async function addNote(id, note) {
    if (!note.trim()) return;
    try {
      const today=new Date().toISOString().slice(0,10);
      const r=repairs.find(x=>x.id===id)||selected;
      const notes=(r.notes?r.notes+"\n":"")+note;
      const history=[...(r.history||[]),{date:today,event:note}];
      await sbFetch(`repairs?id=eq.${encodeURIComponent(id)}`,{method:"PATCH",body:JSON.stringify({notes,history}),prefer:"return=representation"});
      setSelected(p=>p?{...p,notes,history}:p);
      setRepairs(p=>p.map(r=>r.id===id?{...r,notes,history}:r));
      setNoteInput("");
    } catch(e){alert("Error: "+e.message);}
  }

  async function sendQuote(repairId, quote, message) {
    try {
      const res = await fetch(`${SERVER_URL}/send-quote`,{
        method:"POST", headers:{"Content-Type":"application/json"},
        body:JSON.stringify({repairId, quote:parseFloat(quote), message})
      });
      const data=await res.json();
      if(!res.ok) throw new Error(data.error);
      setNotification({type:"success",msg:"Quote SMS sent!"});
      setQuoteModal(null); await load();
      setTimeout(()=>setNotification(null),4000);
    } catch(e){
      setNotification({type:"error",msg:"Failed: "+e.message});
      setTimeout(()=>setNotification(null),5000);
    }
  }

  function scan() {
    const q=scanInput.trim().toLowerCase();
    const found=repairs.find(r=>r.id.toLowerCase()===q||(r.phone&&r.phone.replace(/\s/g,"").includes(q.replace(/\s/g,""))));
    if(found){setScanResult(found);setScanError(false);}
    else{setScanResult(null);setScanError(true);}
  }

  function deadlineBadge(d) {
    if(!d) return null;
    const days=Math.floor((new Date()-new Date(d))/86400000);
    if(days>=9) return {label:`${days}d ⚠️ OVERDUE`,color:"#ef4444",bg:"#1a0000"};
    if(days>=6) return {label:`${days}d ⚡ Due soon`,color:"#f59e0b",bg:"#1a1200"};
    return null;
  }

  const filtered = repairs.filter(r=>{
    const q=search.toLowerCase();
    return (!q||(r.customer_name||"").toLowerCase().includes(q)||(r.id||"").toLowerCase().includes(q)||(r.watch_brand||"").toLowerCase().includes(q)||(r.phone||"").includes(q))
      && (filterStatus==="All"||r.status===filterStatus);
  });
  const counts = ALL_STATUSES.reduce((a,s)=>({...a,[s]:repairs.filter(r=>r.status===s).length}),{});

  if (view==="customer"&&selected) return <CustomerPage repair={selected} onBack={()=>setView("detail")} />;

  const iStyle = {width:"100%",background:"#0f0f1a",border:"1px solid #fff2",color:"#fff",borderRadius:10,padding:"10px 14px",fontSize:15,boxSizing:"border-box",outline:"none"};

  return (
    <div style={{minHeight:"100vh",background:"#0f0f1a",color:"#fff",display:"flex"}}>

      {notification && <div style={{position:"fixed",top:20,right:20,zIndex:1000,background:notification.type==="success"?"#065f46":"#7f1d1d",border:`1px solid ${notification.type==="success"?"#10b981":"#ef4444"}`,color:"#fff",borderRadius:10,padding:"14px 20px",fontSize:14,fontWeight:600,boxShadow:"0 4px 20px #0005",maxWidth:340}}>
        {notification.type==="success"?"✅ ":"❌ "}{notification.msg}
      </div>}

      {quoteModal && <QuoteModal repair={repairs.find(x=>x.id===quoteModal)} onSend={sendQuote} onClose={()=>setQuoteModal(null)} iStyle={iStyle} />}

      {view==="responding" && <div style={{flex:1,display:"flex",alignItems:"center",justifyContent:"center"}}><div style={{textAlign:"center",color:"#fff6"}}><div style={{fontSize:32,marginBottom:16}}>⏳</div><div>Processing…</div></div></div>}
      {(view==="response_done"||view==="response_error")&&selected && (
        <div style={{flex:1,display:"flex",alignItems:"center",justifyContent:"center",background:"#f8f7f4"}}>
          <div style={{background:"#fff",borderRadius:20,padding:40,maxWidth:420,textAlign:"center",boxShadow:"0 4px 24px #0001"}}>
            <div style={{fontSize:48,marginBottom:16}}>{view==="response_error"?"❌":selected.response==="go"?"✅":"❌"}</div>
            <div style={{fontSize:24,fontWeight:700,color:"#1a1a2e",marginBottom:12}}>
              {view==="response_error"?"Something went wrong":selected.response==="go"?"Go Ahead Confirmed!":"No Problem!"}
            </div>
            <div style={{fontSize:15,color:"#6b7280",lineHeight:1.7}}>
              {view==="response_error"?"Couldn't record your response. Please call us.":selected.response==="go"?"We'll get started on your repair right away!":"We've noted your decision. Please contact us to discuss."}
            </div>
            <div style={{marginTop:24,fontSize:13,color:"#9ca3af"}}>⌚ Chrono Repair Studio</div>
          </div>
        </div>
      )}

      {/* Sidebar */}
      <div className="sidebar">
        <div style={{padding:"22px 18px",borderBottom:"1px solid #fff1"}}>
          <div style={{color:"#c9a84c",fontSize:20,fontWeight:700,letterSpacing:".08em"}}>⌚ CHRONO</div>
          <div style={{color:"#fff4",fontSize:12,letterSpacing:".1em",marginTop:2}}>REPAIR STUDIO</div>
        </div>
        {[{id:"dashboard",label:"Dashboard",icon:"▦"},{id:"scan",label:"Scan / Lookup",icon:"⊙"},{id:"new",label:"New Repair",icon:"+"}].map(item=>(
          <button key={item.id} onClick={()=>{setView(item.id);setSelected(null);}}
            style={{background:view===item.id?"#fff1":"transparent",border:"none",borderLeft:view===item.id?"3px solid #c9a84c":"3px solid transparent",color:view===item.id?"#fff":"#fff6",padding:"11px 18px",textAlign:"left",cursor:"pointer",fontSize:15,display:"flex",alignItems:"center",gap:10}}>
            <span>{item.icon}</span>{item.label}
          </button>
        ))}
        <div style={{marginTop:"auto",padding:"14px 18px",borderTop:"1px solid #fff1"}}>
          <div style={{fontSize:11,color:"#fff3",letterSpacing:".06em",marginBottom:8}}>STATUS SUMMARY</div>
          {ALL_STATUSES.filter(s=>counts[s]>0).map(s=>(
            <div key={s} style={{display:"flex",justifyContent:"space-between",fontSize:13,color:"#fff5",marginBottom:3}}>
              <span>{s}</span><span style={{color:STATUS_CONFIG[s].color,fontWeight:700}}>{counts[s]}</span>
            </div>
          ))}
          <button onClick={load} style={{marginTop:12,width:"100%",background:"transparent",border:"1px solid #fff2",color:"#fff5",borderRadius:8,padding:"5px",cursor:"pointer",fontSize:11}}>↻ Refresh</button>
        </div>
      </div>

      {/* Main */}
      <div className="main-scroll" style={{flex:1,overflow:"auto"}}>

        {/* DASHBOARD */}
        {view==="dashboard"&&!selected&&(
          <div style={{padding:"20px 16px"}}>
            <div style={{display:"flex",alignItems:"center",justifyContent:"space-between",marginBottom:20}}>
              <div>
                <h1 style={{margin:0,fontSize:22}}>Repair Jobs</h1>
                <div style={{color:"#fff5",fontSize:14,marginTop:2}}>{repairs.length} total</div>
              </div>
              <button onClick={()=>setView("new")} style={{background:"#c9a84c",color:"#1a1a2e",border:"none",padding:"9px 18px",borderRadius:10,cursor:"pointer",fontWeight:700,fontSize:13}}>+ New</button>
            </div>
            {error&&<div style={{background:"#1a1a2e",border:"1px solid #ef4444",borderRadius:10,padding:16,color:"#ef4444",marginBottom:16}}>{error}</div>}
            <div style={{display:"flex",gap:10,marginBottom:20,flexWrap:"wrap"}}>
              <input placeholder="Search name, ID, brand, phone…" value={search} onChange={e=>setSearch(e.target.value)}
                style={{flex:1,minWidth:200,background:"#fff1",border:"1px solid #fff2",color:"#fff",borderRadius:10,padding:"9px 12px",fontSize:14,outline:"none"}} />
              <select value={filterStatus} onChange={e=>setFilterStatus(e.target.value)}
                style={{background:"#fff1",border:"1px solid #fff2",color:"#fff",borderRadius:10,padding:"9px 12px",fontSize:14,cursor:"pointer"}}>
                <option value="All">All Statuses</option>
                {ALL_STATUSES.map(s=><option key={s} value={s}>{s}</option>)}
              </select>
            </div>
            {loading?<div style={{textAlign:"center",padding:60,color:"#fff3"}}>Loading…</div>:(<>
              {/* Desktop table */}
              <div className="desktop-table" style={{background:"#1a1a2e",borderRadius:12,overflow:"hidden"}}>
                <div style={{display:"grid",gridTemplateColumns:"140px 1fr 1fr 110px 160px 70px 90px",padding:"10px 16px",borderBottom:"1px solid #fff1",fontSize:11,color:"#fff4",letterSpacing:".07em"}}>
                  <span>TICKET</span><span>CUSTOMER</span><span>WATCH</span><span>TEAM</span><span>STATUS</span><span>QUOTE</span><span>DATE IN</span>
                </div>
                {filtered.length===0&&<div style={{padding:40,textAlign:"center",color:"#fff3"}}>No repairs found</div>}
                {filtered.map((r,i)=>(
                  <div key={r.id} onClick={()=>{setSelected(r);setView("detail");}}
                    style={{display:"grid",gridTemplateColumns:"140px 1fr 1fr 110px 160px 70px 90px",padding:"12px 16px",cursor:"pointer",borderBottom:i<filtered.length-1?"1px solid #fff1":"none"}}
                    onMouseEnter={e=>e.currentTarget.style.background="#fff1"} onMouseLeave={e=>e.currentTarget.style.background="transparent"}>
                    <span style={{color:"#c9a84c",fontSize:13,fontWeight:600}}>{r.id}</span>
                    <div><div style={{fontSize:13}}>{r.customer_name}</div><div style={{fontSize:11,color:"#fff4",marginTop:1}}>{r.phone}</div></div>
                    <span style={{fontSize:13,color:"#fff8",alignSelf:"center"}}>{r.watch_brand}</span>
                    <span style={{fontSize:12,color:"#fff5",alignSelf:"center"}}>{r.team_member}</span>
                    <div style={{alignSelf:"center",display:"flex",flexDirection:"column",gap:3}}>
                      <StatusBadge status={r.status} />
                      {deadlineBadge(r.received_date)&&<span style={{fontSize:10,fontWeight:700,color:deadlineBadge(r.received_date).color,background:deadlineBadge(r.received_date).bg,borderRadius:4,padding:"1px 5px",border:`1px solid ${deadlineBadge(r.received_date).color}40`}}>{deadlineBadge(r.received_date).label}</span>}
                    </div>
                    <span style={{fontSize:13,alignSelf:"center"}}>{r.quote!=null?`$${r.quote}`:"—"}</span>
                    <span style={{fontSize:11,color:"#fff5",alignSelf:"center"}}>{r.received_date||"—"}</span>
                  </div>
                ))}
              </div>
              {/* Mobile cards */}
              <div className="mobile-cards">
                {filtered.length===0&&<div style={{padding:40,textAlign:"center",color:"#fff3"}}>No repairs found</div>}
                {filtered.map(r=>(
                  <div key={r.id} onClick={()=>{setSelected(r);setView("detail");}}
                    style={{background:"#1a1a2e",borderRadius:12,padding:16,marginBottom:10,cursor:"pointer",border:"1px solid #fff1"}}>
                    <div style={{display:"flex",justifyContent:"space-between",alignItems:"flex-start",marginBottom:8}}>
                      <span style={{color:"#c9a84c",fontSize:13,fontWeight:700}}>{r.id}</span>
                      <StatusBadge status={r.status} />
                    </div>
                    <div style={{fontSize:17,fontWeight:700,marginBottom:3}}>{r.customer_name||"—"}</div>
                    <div style={{fontSize:14,color:"#fff6",marginBottom:8}}>{r.watch_brand||"—"}</div>
                    <div style={{display:"flex",justifyContent:"space-between",fontSize:12,color:"#fff4"}}>
                      <span>📞 {r.phone||"—"}</span>
                      <span>{r.quote!=null?`$${r.quote}`:"No quote"}</span>
                      <span>{r.received_date||"—"}</span>
                    </div>
                    {deadlineBadge(r.received_date)&&<div style={{marginTop:8}}>
                      <span style={{fontSize:11,fontWeight:700,color:deadlineBadge(r.received_date).color,background:deadlineBadge(r.received_date).bg,borderRadius:4,padding:"2px 8px",border:`1px solid ${deadlineBadge(r.received_date).color}40`}}>{deadlineBadge(r.received_date).label}</span>
                    </div>}
                  </div>
                ))}
              </div>
            </>)}
          </div>
        )}

        {/* DETAIL */}
        {view==="detail"&&selected&&(
          <div style={{padding:"20px 16px",maxWidth:900}}>
            <div style={{display:"flex",alignItems:"center",gap:12,marginBottom:24,flexWrap:"wrap"}}>
              <button onClick={()=>{setSelected(null);setView("dashboard");}} style={{background:"transparent",border:"1px solid #fff3",color:"#fff",padding:"6px 14px",borderRadius:8,cursor:"pointer",fontSize:13}}>← Back</button>
              <h1 style={{margin:0,fontSize:18}}>{selected.id}</h1>
              <StatusBadge status={selected.status} />
              <div style={{marginLeft:"auto",display:"flex",gap:8,flexWrap:"wrap"}}>
                {selected.phone&&<button onClick={()=>setQuoteModal(selected.id)} style={{background:"#10b981",color:"#fff",border:"none",padding:"7px 14px",borderRadius:8,cursor:"pointer",fontWeight:700,fontSize:13}}>💬 Quote</button>}
                <button onClick={()=>printTicket(selected)} style={{background:"#fff2",color:"#fff",border:"1px solid #fff3",padding:"7px 14px",borderRadius:8,cursor:"pointer",fontSize:13}}>🖨 Print</button>
                <button onClick={()=>setView("customer")} style={{background:"#c9a84c",color:"#1a1a2e",border:"none",padding:"7px 14px",borderRadius:8,cursor:"pointer",fontWeight:700,fontSize:13}}>👁 Customer View</button>
              </div>
            </div>
            <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:16,marginBottom:16}}>
              <div style={{background:"#1a1a2e",borderRadius:12,padding:18}}>
                <div style={{fontSize:11,color:"#fff4",letterSpacing:".08em",marginBottom:10}}>CUSTOMER</div>
                <div style={{fontSize:20,fontWeight:700,marginBottom:6}}>{selected.customer_name}</div>
                <div style={{fontSize:14,color:"#fff7",marginBottom:3}}>📞 {selected.phone||"—"}</div>
                <div style={{fontSize:14,color:"#fff5"}}>👤 {selected.team_member||"—"}</div>
              </div>
              <div style={{background:"#1a1a2e",borderRadius:12,padding:18}}>
                <div style={{fontSize:11,color:"#fff4",letterSpacing:".08em",marginBottom:10}}>WATCH</div>
                <div style={{fontSize:20,fontWeight:700,marginBottom:6}}>{selected.watch_brand||"—"}</div>
                <div style={{fontSize:14,color:"#fff5"}}>In: {selected.received_date}</div>
                <div style={{fontSize:14,color:"#fff5",marginTop:3}}>Ready: {selected.estimated_ready||"TBC"}</div>
              </div>
              <div style={{background:"#1a1a2e",borderRadius:12,padding:18}}>
                <div style={{fontSize:11,color:"#fff4",letterSpacing:".08em",marginBottom:10}}>FINANCIALS</div>
                <div style={{display:"flex",justifyContent:"space-between",marginBottom:8}}>
                  <span style={{color:"#fff6",fontSize:14}}>Cost to Business</span>
                  <span style={{fontWeight:700}}>{selected.cost_to_business!=null?`$${selected.cost_to_business}`:"—"}</span>
                </div>
                <div style={{display:"flex",justifyContent:"space-between"}}>
                  <span style={{color:"#fff6",fontSize:14}}>Quote to Customer</span>
                  <span style={{fontWeight:700,color:"#c9a84c"}}>{selected.quote!=null?`$${selected.quote}`:"—"}</span>
                </div>
              </div>
              <div style={{background:"#1a1a2e",borderRadius:12,padding:18,display:"flex",flexDirection:"column",alignItems:"center",justifyContent:"center",gap:8}}>
                <div style={{fontSize:11,color:"#fff4",letterSpacing:".08em"}}>QR CODE</div>
                <QRCode id={selected.id} size={100} />
                <button onClick={()=>printTicket(selected)} style={{background:"#c9a84c",color:"#1a1a2e",border:"none",padding:"6px 14px",borderRadius:6,cursor:"pointer",fontWeight:700,fontSize:12}}>🖨 Print</button>
              </div>
            </div>
            {selected.issue&&<div style={{background:"#1a1a2e",borderRadius:12,padding:18,marginBottom:16}}>
              <div style={{fontSize:11,color:"#fff4",letterSpacing:".08em",marginBottom:8}}>WORK BEING DONE</div>
              <div style={{fontSize:14,color:"#fff9",lineHeight:1.7,whiteSpace:"pre-wrap"}}>{selected.issue}</div>
            </div>}
            <div style={{background:"#1a1a2e",borderRadius:12,padding:18,marginBottom:16}}>
              <div style={{fontSize:11,color:"#fff4",letterSpacing:".08em",marginBottom:12}}>UPDATE STATUS</div>
              <div style={{display:"flex",flexWrap:"wrap",gap:6}}>
                {ALL_STATUSES.map(s=>(
                  <button key={s} onClick={()=>changeStatus(selected.id,s)}
                    style={{background:selected.status===s?STATUS_CONFIG[s].color:"transparent",border:`1px solid ${STATUS_CONFIG[s].color}`,color:selected.status===s?"#fff":STATUS_CONFIG[s].color,padding:"6px 14px",borderRadius:20,cursor:"pointer",fontSize:13,fontWeight:600}}>{s}</button>
                ))}
              </div>
            </div>
            <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:16}}>
              <div style={{background:"#1a1a2e",borderRadius:12,padding:18}}>
                <div style={{fontSize:11,color:"#fff4",letterSpacing:".08em",marginBottom:10}}>NOTES</div>
                <div style={{fontSize:13,color:"#fff7",lineHeight:1.7,marginBottom:14,whiteSpace:"pre-wrap",minHeight:36}}>{selected.notes||"No notes yet."}</div>
                <textarea placeholder="Add a note…" value={noteInput} onChange={e=>setNoteInput(e.target.value)}
                  style={{width:"100%",background:"#0f0f1a",border:"1px solid #fff2",color:"#fff",borderRadius:8,padding:10,fontSize:13,minHeight:70,resize:"vertical",boxSizing:"border-box",outline:"none"}} />
                <button onClick={()=>addNote(selected.id,noteInput)} style={{marginTop:8,background:"#c9a84c",color:"#1a1a2e",border:"none",padding:"7px 16px",borderRadius:6,cursor:"pointer",fontWeight:700,fontSize:13}}>Add Note</button>
              </div>
              <div style={{background:"#1a1a2e",borderRadius:12,padding:18}}>
                <div style={{fontSize:11,color:"#fff4",letterSpacing:".08em",marginBottom:12}}>HISTORY</div>
                {(selected.history||[]).slice().reverse().map((h,i)=>(
                  <div key={i} style={{display:"flex",gap:10,marginBottom:10}}>
                    <div style={{width:8,height:8,borderRadius:"50%",background:i===0?"#c9a84c":"#fff2",marginTop:4,flexShrink:0}} />
                    <div>
                      <div style={{fontSize:11,color:"#fff3"}}>{h.date}</div>
                      <div style={{fontSize:13,color:"#fff7",marginTop:1}}>{h.event}</div>
                    </div>
                  </div>
                ))}
              </div>
            </div>
          </div>
        )}

        {/* SCAN */}
        {view==="scan"&&(
          <div style={{padding:"20px 16px",maxWidth:540}}>
            <h1 style={{margin:"0 0 8px",fontSize:22}}>Scan / Lookup</h1>
            <p style={{color:"#fff5",marginBottom:24,fontSize:14}}>Enter a ticket ID or phone number.</p>
            <div style={{display:"flex",gap:10,marginBottom:20}}>
              <input placeholder="Ticket ID or phone…" value={scanInput} onChange={e=>{setScanInput(e.target.value);setScanError(false);setScanResult(null);}} onKeyDown={e=>e.key==="Enter"&&scan()}
                style={{flex:1,background:"#1a1a2e",border:"1px solid #fff3",color:"#fff",borderRadius:10,padding:"11px 14px",fontSize:15,outline:"none"}} />
              <button onClick={scan} style={{background:"#c9a84c",color:"#1a1a2e",border:"none",padding:"0 20px",borderRadius:10,cursor:"pointer",fontWeight:700,fontSize:14}}>Find</button>
            </div>
            {scanError&&<div style={{background:"#1a1a2e",border:"1px solid #ef444450",borderRadius:10,padding:16,color:"#ef4444",fontSize:14}}>No repair found.</div>}
            {scanResult&&<div style={{background:"#1a1a2e",borderRadius:12,padding:20}}>
              <div style={{display:"flex",justifyContent:"space-between",alignItems:"flex-start",marginBottom:14}}>
                <div>
                  <div style={{color:"#c9a84c",fontSize:14,fontWeight:700}}>{scanResult.id}</div>
                  <div style={{fontSize:20,fontWeight:700,marginTop:3}}>{scanResult.customer_name}</div>
                  <div style={{color:"#fff6",marginTop:3}}>{scanResult.watch_brand}</div>
                </div>
                <StatusBadge status={scanResult.status} />
              </div>
              <div style={{display:"flex",gap:10}}>
                <button onClick={()=>{setSelected(scanResult);setView("detail");}} style={{flex:1,background:"#c9a84c",color:"#1a1a2e",border:"none",padding:10,borderRadius:8,cursor:"pointer",fontWeight:700}}>Open</button>
                <button onClick={()=>printTicket(scanResult)} style={{flex:1,background:"transparent",color:"#fff",border:"1px solid #fff3",padding:10,borderRadius:8,cursor:"pointer"}}>🖨 Print</button>
              </div>
            </div>}
          </div>
        )}

        {/* NEW REPAIR */}
        {view==="new"&&<NewRepairForm iStyle={iStyle} saving={saving} form={form} setForm={setForm} onSave={saveRepair} />}
      </div>

      {/* Mobile bottom nav */}
      <div className="bottom-nav">
        {[{id:"dashboard",label:"Jobs",icon:"▦"},{id:"scan",label:"Lookup",icon:"⊙"},{id:"new",label:"New",icon:"+"}].map(item=>(
          <button key={item.id} onClick={()=>{setView(item.id);setSelected(null);}}
            style={{background:"transparent",border:"none",color:view===item.id?"#c9a84c":"#fff5",cursor:"pointer",display:"flex",flexDirection:"column",alignItems:"center",gap:4,padding:"4px 24px"}}>
            <span style={{fontSize:22}}>{item.icon}</span>
            <span style={{fontSize:11}}>{item.label}</span>
          </button>
        ))}
      </div>
    </div>
  );
}

ReactDOM.createRoot(document.getElementById("root")).render(<App />);
</script>
</body>
</html>
